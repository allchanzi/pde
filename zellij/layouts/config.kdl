layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="terminal" focus=true {
        pane
    }
    tab name="editor" {
        pane command="zsh" {
            args "-lc" "run-and-return-to-shell nvim ."
        }
    }
    tab name="ai" {
        pane split_direction="vertical" {
            pane command="zsh" {
                args "-lc" "run-and-return-to-shell codex"
            }
            pane command="zsh" {
                args "-lc" "run-and-return-to-shell claude"
            }
        }
    }
    tab name="git" {
        pane command="zsh" {
            args "-lc" "run-and-return-to-shell lazygit"
        }
    }
}
