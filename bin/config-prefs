#!/usr/bin/env bash

CONFIG_PREFS_FILE_DEFAULT="${CONFIG_PREFS_FILE_DEFAULT:-$HOME/.config/config/prefs}"
CONFIG_PREFS_FILE_LEGACY="${CONFIG_PREFS_FILE_LEGACY:-$HOME/.config/shell/prefs}"

_config_prefs_file() {
  if [[ -f "$CONFIG_PREFS_FILE_DEFAULT" ]]; then
    printf '%s\n' "$CONFIG_PREFS_FILE_DEFAULT"
  elif [[ -f "$CONFIG_PREFS_FILE_LEGACY" ]]; then
    printf '%s\n' "$CONFIG_PREFS_FILE_LEGACY"
  else
    printf '%s\n' "$CONFIG_PREFS_FILE_DEFAULT"
  fi
}

config_prefs_migrate() {
  if [[ ! -f "$CONFIG_PREFS_FILE_DEFAULT" && -f "$CONFIG_PREFS_FILE_LEGACY" ]]; then
    mkdir -p "$(dirname "$CONFIG_PREFS_FILE_DEFAULT")"
    cp "$CONFIG_PREFS_FILE_LEGACY" "$CONFIG_PREFS_FILE_DEFAULT"
  fi
}

config_prefs_load() {
  local prefs_file
  prefs_file="$(_config_prefs_file)"
  if [[ -f "$prefs_file" ]]; then
    # shellcheck source=/dev/null
    source "$prefs_file"
  fi
}

config_prefs_get() {
  local key="$1"
  local default="${2:-}"
  config_prefs_load
  eval "printf '%s\n' \"\${$key:-$default}\""
}

config_prefs_save() {
  local key="$1"
  local value="$2"
  local prefs_file="$CONFIG_PREFS_FILE_DEFAULT"
  local quoted
  local tmp
  local updated=0
  local line

  config_prefs_migrate
  mkdir -p "$(dirname "$prefs_file")"
  quoted="${value//\'/\'\\\'\'}"
  tmp="$(mktemp)"

  if [[ -f "$prefs_file" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" == "$key="* ]]; then
        printf "%s='%s'\n" "$key" "$quoted" >> "$tmp"
        updated=1
      else
        printf '%s\n' "$line" >> "$tmp"
      fi
    done < "$prefs_file"
  fi

  if [[ "$updated" -eq 0 ]]; then
    printf "%s='%s'\n" "$key" "$quoted" >> "$tmp"
  fi

  mv "$tmp" "$prefs_file"
}

config_prefs_bool() {
  local key="$1"
  local default="${2:-0}"
  local value

  value="$(config_prefs_get "$key" "$default")"
  case "$value" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}
