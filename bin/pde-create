#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET"
  fi
done
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

PDE_PREFS_HELPER="$BIN_DIR/pde-prefs"
if [[ -f "$PDE_PREFS_HELPER" ]]; then
  # shellcheck source=/dev/null
  source "$PDE_PREFS_HELPER"
  pde_prefs_migrate
  pde_prefs_load
fi

usage() {
  cat <<USAGE
Usage:
  pde-create <command-name> <project-dir> [options]

Options:
  --minimal       Generate: terminal, editor, ai, git
  --full          Generate: terminal, editor, ai, git, docker, k9s, monitor
  --no-ai         Omit AI window
  --no-docker     Omit docker window
  --base-branch   Branch to use as the base for new worktrees
  --dotfiles      Optimized preset for a dotfiles/config repo
  -h, --help      Show this help

Examples:
  pde-create example-proj-name ~/git/example-proj-name --full
  pde-create example-proj-name ~/git/example-proj-name --full --base-branch main
  pde-create example-dotfiles-repo ~/git/example-dotfiles-repo --dotfiles
  pde-create example-proj-name ~/git/example-proj-name --minimal --no-ai
USAGE
}

if [[ $# -eq 1 && ( "$1" == "-h" || "$1" == "--help" ) ]]; then
  usage; exit 0
fi

if [[ $# -lt 2 ]]; then
  usage; exit 1
fi

COMMAND_NAME="$1"
PROJECT_DIR_INPUT="$2"
shift 2

LAYOUT="minimal"
WITH_AI=1
WITH_DOCKER=1
DOTFILES_MODE=0
BASE_BRANCH=""
AI_PROFILE="${AI_PROFILE:-codex+claude}"
AI_COMMAND_1="${AI_COMMAND_1:-codex}"
AI_COMMAND_2="${AI_COMMAND_2:-claude}"

if [[ "$AI_PROFILE" == "none" ]]; then
  AI_COMMAND_1=""
  AI_COMMAND_2=""
fi

escape_kdl() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

wrap_shell_command() {
  local value="$1"
  printf '%s; exec "$SHELL" -l' "$value"
}

resolve_project_dir() {
  local input="$1"
  local expanded="${input/#\~/$HOME}"
  local parent
  local base

  if [[ -d "$expanded" ]]; then
    (cd "$expanded" && pwd -P)
    return 0
  fi

  parent="$(dirname "$expanded")"
  base="$(basename "$expanded")"

  if [[ "$expanded" == /* ]]; then
    if [[ -d "$parent" ]]; then
      printf '%s/%s\n' "$(cd "$parent" && pwd -P)" "$base"
    else
      printf '%s\n' "$expanded"
    fi
    return 0
  fi

  if [[ "$parent" == "." ]]; then
    printf '%s/%s\n' "$(pwd -P)" "$base"
  elif [[ -d "$parent" ]]; then
    printf '%s/%s\n' "$(cd "$parent" && pwd -P)" "$base"
  else
    printf '%s/%s\n' "$(pwd -P)" "$expanded"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --minimal)    LAYOUT="minimal"; shift ;;
    --full)       LAYOUT="full"; shift ;;
    --no-ai)      WITH_AI=0; shift ;;
    --no-docker)  WITH_DOCKER=0; shift ;;
    --base-branch) BASE_BRANCH="${2:-}"; shift 2 ;;
    --dotfiles)   DOTFILES_MODE=1; LAYOUT="minimal"; WITH_DOCKER=0; shift ;;
    -h|--help)    usage; exit 0 ;;
    *) echo "Unknown option: $1"; usage; exit 1 ;;
  esac
done

PROJECT_DIR="$(resolve_project_dir "$PROJECT_DIR_INPUT")"

TARGET="$HOME/bin/$COMMAND_NAME"
ZELLIJ_LAYOUT="$HOME/.config/zellij/layouts/${COMMAND_NAME}.kdl"

# ── Preflight checks ──────────────────────────────────────────────────────────

mkdir -p "$HOME/bin"
mkdir -p "$HOME/.config/zellij/layouts"

WARNINGS=()

if [[ ! -d "$PROJECT_DIR" ]]; then
  WARNINGS+=("Project dir does not exist yet: $PROJECT_DIR")
fi

for tool in nvim lazygit; do
  command -v "$tool" >/dev/null 2>&1 || WARNINGS+=("$tool not found — run: brew install $tool")
done

if ! command -v tmux >/dev/null 2>&1 && ! command -v zellij >/dev/null 2>&1; then
  WARNINGS+=("No multiplexer found — run: brew install tmux  (or zellij)")
fi

if [[ "$WITH_AI" -eq 1 && -n "$AI_COMMAND_1" ]]; then
  command -v "${AI_COMMAND_1%% *}" >/dev/null 2>&1 || WARNINGS+=("${AI_COMMAND_1%% *} not found — configure or install the selected AI command")
fi
if [[ "$WITH_AI" -eq 1 && -n "$AI_COMMAND_2" ]]; then
  command -v "${AI_COMMAND_2%% *}" >/dev/null 2>&1 || WARNINGS+=("${AI_COMMAND_2%% *} not found — configure or install the selected AI command")
fi

if [[ "$LAYOUT" == "full" && "$WITH_DOCKER" -eq 1 ]]; then
  command -v lazydocker >/dev/null 2>&1 || WARNINGS+=("lazydocker not found — run: brew install lazydocker")
fi
if [[ "$LAYOUT" == "full" ]]; then
  command -v k9s >/dev/null 2>&1 || WARNINGS+=("k9s not found — run: brew install k9s")
fi

# ── Generate zellij layout ────────────────────────────────────────────────────

generate_zellij_layout() {
  local tabs=""

  tabs+='    tab name="terminal" focus=true {\n        pane\n    }\n'
  tabs+='    tab name="editor" {\n        pane command="zsh" {\n            args "-lc" "nvim .; exec \"$SHELL\" -l"\n        }\n    }\n'

  if [[ "$WITH_AI" -eq 1 && -n "$AI_COMMAND_1" ]]; then
    if [[ -n "$AI_COMMAND_2" ]]; then
      tabs+="    tab name=\"ai\" {\n        pane split_direction=\"vertical\" {\n            pane command=\"zsh\" {\n                args \"-lc\" \"$(escape_kdl "$(wrap_shell_command "$AI_COMMAND_1")")\"\n            }\n            pane command=\"zsh\" {\n                args \"-lc\" \"$(escape_kdl "$(wrap_shell_command "$AI_COMMAND_2")")\"\n            }\n        }\n    }\n"
    else
      tabs+="    tab name=\"ai\" {\n        pane command=\"zsh\" {\n            args \"-lc\" \"$(escape_kdl "$(wrap_shell_command "$AI_COMMAND_1")")\"\n        }\n    }\n"
    fi
  fi

  tabs+='    tab name="git" {\n        pane command="zsh" {\n            args "-lc" "lazygit; exec \"$SHELL\" -l"\n        }\n    }\n'

  if [[ "$DOTFILES_MODE" -eq 0 ]]; then
    tabs+='    tab name="term2" {\n        pane\n    }\n'
  fi

  if [[ "$LAYOUT" == "full" && "$WITH_DOCKER" -eq 1 ]]; then
    tabs+='    tab name="docker" {\n        pane command="zsh" {\n            args "-lc" "lazydocker; exec \"$SHELL\" -l"\n        }\n    }\n'
  fi

  if [[ "$LAYOUT" == "full" ]]; then
    tabs+='    tab name="k9s" {\n        pane command="zsh" {\n            args "-lc" "k9s; exec \"$SHELL\" -l"\n        }\n    }\n'
    tabs+='    tab name="monitor" {\n        pane split_direction="horizontal" {\n            pane command="zsh" {\n                args "-lc" "if command -v network-ports >/dev/null 2>&1; then network-ports; else bash -lc '\''while true; do clear; lsof -nP -iTCP; sleep 2; done'\''; fi; exec \"$SHELL\" -l"\n            }\n            pane command="zsh" {\n                args "-lc" "btop -p 1; exec \"$SHELL\" -l"\n            }\n        }\n    }\n'
  fi

  mkdir -p "$(dirname "$ZELLIJ_LAYOUT")"
  printf 'layout {\n    default_tab_template {\n        pane size=1 borderless=true {\n            plugin location="tab-bar"\n        }\n        children\n        pane size=1 borderless=true {\n            plugin location="status-bar"\n        }\n    }\n\n%b}\n' "$tabs" > "$ZELLIJ_LAYOUT"
}

# ── Generate launcher script ──────────────────────────────────────────────────

cat > "$TARGET" <<SCRIPT
#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="\${BASH_SOURCE[0]}"
while [[ -L "\$SCRIPT_PATH" ]]; do
  LINK_TARGET="\$(readlink "\$SCRIPT_PATH")"
  if [[ "\$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="\$LINK_TARGET"
  else
    SCRIPT_DIR="\$(cd "\$(dirname "\$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="\$SCRIPT_DIR/\$LINK_TARGET"
  fi
done
BIN_DIR="\$(cd "\$(dirname "\$SCRIPT_PATH")" && pwd)"

SESSION_BASE="$COMMAND_NAME"
MAIN_PROJECT_DIR="$PROJECT_DIR"
BASE_BRANCH="$BASE_BRANCH"

BRANCH=""
FORCE=0
DELETE_WORKTREE=0
SHOW_WORKTREE_ORIGIN=0
LIST_WORKTREES=0
LIST_ALL=0
DELETE_ALL=0
FROM_BRANCH=""

usage() {
  echo "Usage:"
  echo "  $COMMAND_NAME"
  echo "  $COMMAND_NAME -b <branch>"
  echo "  $COMMAND_NAME -b <branch> --from <base-branch>"
  echo "  $COMMAND_NAME -d -b <branch>"
  echo "  $COMMAND_NAME -d --all"
  echo "  $COMMAND_NAME -b <branch> -f"
  echo "  $COMMAND_NAME --delete-worktree -b <branch>"
  echo "  $COMMAND_NAME --worktree-origin -b <branch>"
  echo "  $COMMAND_NAME --list"
  echo "  $COMMAND_NAME --list-worktrees"
}

worktree_path_for_branch() {
  git worktree list --porcelain | awk -v branch="refs/heads/\$1" '
    \$1=="worktree" { path=\$2 }
    \$1=="branch" && \$2==branch { print path }
  '
}

worktree_default_path_for_branch() {
  local repo_name
  local safe_branch
  local worktree_root

  repo_name="\$(basename "\$MAIN_PROJECT_DIR")"
  safe_branch="\${1//\//-}"
  worktree_root="\$(dirname "\$MAIN_PROJECT_DIR")"
  printf '%s/%s-%s\n' "\$worktree_root" "\$repo_name" "\$safe_branch"
}

worktree_session_name_for_branch() {
  local safe_branch

  safe_branch="\${1//\//-}"
  printf '%s-%s\n' "\$SESSION_BASE" "\$safe_branch"
}

delete_local_branch_if_requested() {
  if ! git show-ref --verify --quiet "refs/heads/\$1"; then
    return 0
  fi

  if [[ "\$FORCE" -ne 1 ]]; then
    echo "Branch '\$1' already exists locally. Use -f to recreate it from a different base." >&2
    exit 1
  fi

  git branch -D "\$1" >/dev/null 2>&1 || {
    echo "Could not delete local branch '\$1'." >&2
    exit 1
  }
}

resolve_base_start_point() {
  git fetch origin "\$1" --prune 2>/dev/null || true

  if git show-ref --verify --quiet "refs/remotes/origin/\$1"; then
    printf 'origin/%s\n' "\$1"
    return 0
  fi

  if git show-ref --verify --quiet "refs/heads/\$1"; then
    printf '%s\n' "\$1"
    return 0
  fi

  return 1
}

write_worktree_metadata() {
  local worktree_path="\$1"
  local branch="\$2"
  local origin_ref="\$3"
  local origin_kind="\$4"
  local git_dir
  local metadata_file

  git_dir="\$(git -C "\$worktree_path" rev-parse --git-dir)"
  metadata_file="\$git_dir/pde-worktree-meta"

  cat > "\$metadata_file" <<EOF
branch=\$branch
origin_ref=\$origin_ref
origin_kind=\$origin_kind
created_at=\$(date -u +"%Y-%m-%dT%H:%M:%SZ")
EOF
}

show_worktree_origin() {
  local branch="\$1"
  local worktree_path
  local git_dir
  local metadata_file
  local upstream

  worktree_path="\$(worktree_path_for_branch "\$branch")"
  if [[ -z "\$worktree_path" ]]; then
    echo "No worktree found for branch '\$branch'." >&2
    return 1
  fi

  git_dir="\$(git -C "\$worktree_path" rev-parse --git-dir)"
  metadata_file="\$git_dir/pde-worktree-meta"

  echo "worktree: \$worktree_path"
  echo "branch:   \$branch"

  if [[ -f "\$metadata_file" ]]; then
    grep -E '^(origin_ref|origin_kind|created_at)=' "\$metadata_file" | sed 's/^origin_ref=/origin:   /; s/^origin_kind=/kind:     /; s/^created_at=/created:  /'
    return 0
  fi

  upstream="\$(git -C "\$worktree_path" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
  if [[ -n "\$upstream" ]]; then
    echo "origin:   \$upstream"
    echo "kind:     upstream"
    return 0
  fi

  echo "origin:   unknown (worktree was created before metadata support)"
}

delete_worktree() {
  local branch="\$1"
  local worktree_path
  local session

  worktree_path="\$(worktree_path_for_branch "\$branch")"
  if [[ -z "\$worktree_path" ]]; then
    worktree_path="\$(worktree_default_path_for_branch "\$branch")"
  fi

  if [[ ! -e "\$worktree_path" ]]; then
    echo "No worktree path found for branch '\$branch'." >&2
    return 1
  fi

  session="\$(worktree_session_name_for_branch "\$branch")"
  tmux kill-session -t "\$session" 2>/dev/null || true

  cd "\$MAIN_PROJECT_DIR" || exit 1
  git worktree remove --force "\$worktree_path" 2>/dev/null || true
  rm -rf "\$worktree_path"
  echo "Removed worktree '\$branch' at \$worktree_path"
}

list_worktrees() {
  git worktree list
}

list_all() {
  echo "== tmux sessions =="
  if command -v tmux >/dev/null 2>&1; then
    tmux list-sessions -F '#S' 2>/dev/null | grep -E "^\${SESSION_BASE}(-|$)" || echo "(none)"
  else
    echo "(tmux not installed)"
  fi

  echo
  echo "== zellij sessions =="
  if command -v zellij >/dev/null 2>&1; then
    zellij list-sessions --short --no-formatting 2>/dev/null | grep -E "^\${SESSION_BASE}(-|$)" || echo "(none)"
  else
    echo "(zellij not installed)"
  fi

  echo
  echo "== git worktrees =="
  git worktree list || echo "(none)"
}

delete_all_worktrees() {
  local current_path
  local current_branch_ref
  local current_branch
  local session

  while IFS=\$'\t' read -r current_path current_branch_ref; do
    if [[ "\$current_path" == "\$MAIN_PROJECT_DIR" ]]; then
      continue
    fi

    current_branch="\${current_branch_ref#refs/heads/}"
    if [[ "\$current_branch" != "\$current_branch_ref" ]]; then
      session="\$(worktree_session_name_for_branch "\$current_branch")"
      tmux kill-session -t "\$session" 2>/dev/null || true
    fi

    git worktree remove --force "\$current_path" 2>/dev/null || true
    rm -rf "\$current_path"
    echo "Removed worktree at \$current_path"
  done < <(
    git worktree list --porcelain | awk '
      \$1=="worktree" { path=\$2 }
      \$1=="branch" { print path "\t" \$2 }
    '
  )
}

while [[ \$# -gt 0 ]]; do
  case "\$1" in
    -b|--branch)  BRANCH="\${2:-}"; shift 2 ;;
    --from)       FROM_BRANCH="\${2:-}"; shift 2 ;;
    -d|--delete-worktree) DELETE_WORKTREE=1; shift ;;
    --all) DELETE_ALL=1; shift ;;
    -f|--force)   FORCE=1; shift ;;
    --worktree-origin) SHOW_WORKTREE_ORIGIN=1; shift ;;
    --list) LIST_ALL=1; shift ;;
    --list-worktrees) LIST_WORKTREES=1; shift ;;
    -h|--help)    usage; exit 0 ;;
    *) echo "Unknown argument: \$1"; usage; exit 1 ;;
  esac
done

if [[ -n "\$FROM_BRANCH" ]]; then
  BASE_BRANCH="\$FROM_BRANCH"
fi

cd "\$MAIN_PROJECT_DIR" || exit 1

if [[ "\$LIST_WORKTREES" -eq 1 ]]; then
  list_worktrees
  exit 0
fi

if [[ "\$LIST_ALL" -eq 1 ]]; then
  list_all
  exit 0
fi

if [[ "\$DELETE_WORKTREE" -eq 1 ]]; then
  if [[ "\$DELETE_ALL" -eq 1 ]]; then
    delete_all_worktrees
    exit 0
  fi

  if [[ -z "\$BRANCH" ]]; then
    echo "-d/--delete-worktree requires -b <branch>" >&2
    exit 1
  fi

  delete_worktree "\$BRANCH"
  exit 0
fi

if [[ "\$SHOW_WORKTREE_ORIGIN" -eq 1 ]]; then
  if [[ -z "\$BRANCH" ]]; then
    echo "--worktree-origin requires -b <branch>" >&2
    exit 1
  fi

  show_worktree_origin "\$BRANCH"
  exit 0
fi

PROJECT_DIR="\$MAIN_PROJECT_DIR"
SESSION="\$SESSION_BASE"

if [[ -n "\$BRANCH" ]]; then
  EXISTING_PATH="\$(worktree_path_for_branch "\$BRANCH")"

  if [[ -n "\$EXISTING_PATH" && "\$FORCE" -eq 0 ]]; then
    PROJECT_DIR="\$EXISTING_PATH"
  else
    if [[ -n "\$EXISTING_PATH" && "\$FORCE" -eq 1 ]]; then
      echo "Removing existing worktree for '\$BRANCH' at \$EXISTING_PATH..."
      git worktree remove --force "\$EXISTING_PATH" || true
      rm -rf "\$EXISTING_PATH"
    fi

    REPO_NAME="\$(basename "\$MAIN_PROJECT_DIR")"
    SAFE_BRANCH="\${BRANCH//\//-}"
    WORKTREE_ROOT="\$(dirname "\$MAIN_PROJECT_DIR")"
    WORKTREE_PATH="\$WORKTREE_ROOT/\${REPO_NAME}-\${SAFE_BRANCH}"
    ORIGIN_REF=""
    ORIGIN_KIND=""

    if [[ -n "\$BASE_BRANCH" ]]; then
      START_POINT="\$(resolve_base_start_point "\$BASE_BRANCH")" || {
        echo "Base branch '\$BASE_BRANCH' not found locally or on origin." >&2
        exit 1
      }

      delete_local_branch_if_requested "\$BRANCH"

      ORIGIN_REF="\$START_POINT"
      case "\$START_POINT" in
        origin/*) ORIGIN_KIND="base-remote-branch" ;;
        *) ORIGIN_KIND="base-local-branch" ;;
      esac

      git worktree add "\$WORKTREE_PATH" -b "\$BRANCH" "\$START_POINT"
    else
      git fetch origin "\$BRANCH" --prune 2>/dev/null || true

      if git show-ref --verify --quiet "refs/heads/\$BRANCH"; then
        ORIGIN_REF="\$BRANCH"
        ORIGIN_KIND="local-branch"
        git worktree add "\$WORKTREE_PATH" "\$BRANCH"
      elif git show-ref --verify --quiet "refs/remotes/origin/\$BRANCH"; then
        ORIGIN_REF="origin/\$BRANCH"
        ORIGIN_KIND="remote-branch"
        git worktree add "\$WORKTREE_PATH" -b "\$BRANCH" "origin/\$BRANCH"
        git -C "\$WORKTREE_PATH" branch --set-upstream-to "origin/\$BRANCH" "\$BRANCH" >/dev/null 2>&1 || true
      else
        ORIGIN_REF="\$(git rev-parse --abbrev-ref HEAD)"
        ORIGIN_KIND="current-head"
        git worktree add "\$WORKTREE_PATH" -b "\$BRANCH"
      fi
    fi

    write_worktree_metadata "\$WORKTREE_PATH" "\$BRANCH" "\$ORIGIN_REF" "\$ORIGIN_KIND"
    PROJECT_DIR="\$WORKTREE_PATH"
  fi

  SAFE_BRANCH="\${BRANCH//\//-}"
  SESSION="\${SESSION_BASE}-\${SAFE_BRANCH}"
fi

cd "\$PROJECT_DIR" || exit 1

# ── Multiplexer ───────────────────────────────────────────────────────────────

PDE_PREFS_HELPER="\$BIN_DIR/pde-prefs"
if [[ ! -f "\$PDE_PREFS_HELPER" && -f "\$HOME/bin/pde-prefs" ]]; then
  PDE_PREFS_HELPER="\$HOME/bin/pde-prefs"
fi
if [[ -f "\$PDE_PREFS_HELPER" ]]; then
  # shellcheck source=/dev/null
  source "\$PDE_PREFS_HELPER"
  pde_prefs_migrate
  pde_prefs_load
fi

MULTIPLEXER="\${MULTIPLEXER:-tmux}"
AI_PROFILE="\${AI_PROFILE:-codex+claude}"
AI_COMMAND_1="\${AI_COMMAND_1:-codex}"
AI_COMMAND_2="\${AI_COMMAND_2:-claude}"

if [[ "\$AI_PROFILE" == "none" ]]; then
  AI_COMMAND_1=""
  AI_COMMAND_2=""
fi

zellij_session_exists() {
  zellij list-sessions --short --no-formatting 2>/dev/null | grep -Fxq "\$1"
}

shorten_zellij_session_name() {
  local candidate="\$1"
  local max_len=24
  local hash
  local prefix_len

  if (( \${#candidate} <= max_len )); then
    printf '%s\n' "\$candidate"
    return 0
  fi

  hash="\$(printf '%s' "\$candidate" | shasum -a 1 | awk '{print substr(\$1,1,8)}')"
  prefix_len=\$((max_len - \${#hash} - 1))
  printf '%s-%s\n' "\${candidate:0:prefix_len}" "\$hash"
}

if [[ "\$MULTIPLEXER" == "zellij" ]]; then
  SESSION="\$(shorten_zellij_session_name "\$SESSION")"
  ZELLIJ_LAYOUT="\$HOME/.config/zellij/layouts/${COMMAND_NAME}.kdl"
  [[ -f "\$HOME/.config/zellij/layouts/${COMMAND_NAME}.local.kdl" ]] && ZELLIJ_LAYOUT="\$HOME/.config/zellij/layouts/${COMMAND_NAME}.local.kdl"
  if [[ -n "\${ZELLIJ:-}" ]]; then
    exec zellij action switch-session "\$SESSION" -c "\$PROJECT_DIR" -l "\$ZELLIJ_LAYOUT"
  elif zellij_session_exists "\$SESSION"; then
    exec zellij attach "\$SESSION"
  else
    exec zellij -s "\$SESSION" -n "\$ZELLIJ_LAYOUT"
  fi
  exit 0
fi

# ── tmux ──────────────────────────────────────────────────────────────────────

if tmux has-session -t "\$SESSION" 2>/dev/null; then
  tmux attach-session -t "\$SESSION"
  exit 0
fi

TMUX_LAYOUT_LOCAL="\$HOME/.config/tmux/${COMMAND_NAME}.local.sh"
if [[ -f "\$TMUX_LAYOUT_LOCAL" ]]; then
  # shellcheck source=/dev/null
  source "\$TMUX_LAYOUT_LOCAL"
  if declare -F setup_tmux_layout >/dev/null 2>&1; then
    setup_tmux_layout "\$SESSION" "\$PROJECT_DIR"
    tmux attach-session -t "\$SESSION"
    exit 0
  fi
fi

WINDOW_INDEX=1
tmux new-session -d -s "\$SESSION" -n terminal -c "\$PROJECT_DIR"
WINDOW_INDEX=2

tmux new-window -t "\$SESSION":2 -n editor -c "\$PROJECT_DIR"
tmux send-keys -t "\$SESSION":2 "nvim ." C-m
WINDOW_INDEX=3
SCRIPT

if [[ "$WITH_AI" -eq 1 ]]; then
cat >> "$TARGET" <<'SCRIPT'
if [[ -n "$AI_COMMAND_1" ]]; then
  tmux new-window -t "$SESSION":$WINDOW_INDEX -n ai -c "$PROJECT_DIR"
  tmux send-keys -t "$SESSION":$WINDOW_INDEX "$AI_COMMAND_1" C-m
  if [[ -n "$AI_COMMAND_2" ]]; then
    tmux split-window -h -t "$SESSION":$WINDOW_INDEX
    tmux send-keys -t "$SESSION":$WINDOW_INDEX.2 "$AI_COMMAND_2" C-m
  fi
  WINDOW_INDEX=$((WINDOW_INDEX + 1))
fi
SCRIPT
fi

cat >> "$TARGET" <<'SCRIPT'
tmux new-window -t "$SESSION":$WINDOW_INDEX -n git -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION":$WINDOW_INDEX "lazygit" C-m
WINDOW_INDEX=$((WINDOW_INDEX + 1))
SCRIPT

if [[ "$DOTFILES_MODE" -eq 0 ]]; then
cat >> "$TARGET" <<'SCRIPT'
tmux new-window -t "$SESSION":$WINDOW_INDEX -n term2 -c "$PROJECT_DIR"
WINDOW_INDEX=$((WINDOW_INDEX + 1))
SCRIPT
fi

if [[ "$LAYOUT" == "full" && "$WITH_DOCKER" -eq 1 ]]; then
cat >> "$TARGET" <<'SCRIPT'
tmux new-window -t "$SESSION":$WINDOW_INDEX -n docker -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION":$WINDOW_INDEX "lazydocker" C-m
WINDOW_INDEX=$((WINDOW_INDEX + 1))
SCRIPT
fi

if [[ "$LAYOUT" == "full" ]]; then
cat >> "$TARGET" <<'SCRIPT'
tmux new-window -t "$SESSION":$WINDOW_INDEX -n k9s -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION":$WINDOW_INDEX "k9s" C-m
WINDOW_INDEX=$((WINDOW_INDEX + 1))

tmux new-window -t "$SESSION":$WINDOW_INDEX -n monitor -c "$PROJECT_DIR"
tmux split-window -h -t "$SESSION":$WINDOW_INDEX
tmux send-keys -t "$SESSION":$WINDOW_INDEX.1 "if command -v network-ports >/dev/null 2>&1; then network-ports; else while true; do clear; lsof -nP -iTCP; sleep 2; done; fi" C-m
tmux send-keys -t "$SESSION":$WINDOW_INDEX.2 "btop -p 1" C-m
WINDOW_INDEX=$((WINDOW_INDEX + 1))
SCRIPT
fi

cat >> "$TARGET" <<'SCRIPT'
tmux select-window -t "$SESSION":1
tmux attach-session -t "$SESSION"
SCRIPT

chmod +x "$TARGET"
generate_zellij_layout

echo ""
echo "  launcher  →  $TARGET"
echo "  layout    →  $ZELLIJ_LAYOUT"
echo "  project   →  $PROJECT_DIR"
if [[ -n "$BASE_BRANCH" ]]; then
  echo "  base      →  $BASE_BRANCH"
fi
echo ""

if [[ ${#WARNINGS[@]} -gt 0 ]]; then
  echo "Warnings:"
  for w in "${WARNINGS[@]}"; do
    echo "  ! $w"
  done
  echo ""
fi

echo "Run:  $COMMAND_NAME"
if [[ -n "$BASE_BRANCH" ]]; then
  echo "      $COMMAND_NAME -b <branch>"
fi
