#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_PATH="$LINK_TARGET"
  else
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET"
  fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
source "$SCRIPT_DIR/theme.d/common.sh"
source "$SCRIPT_DIR/theme.d/terminal.sh"
source "$SCRIPT_DIR/theme.d/ux.sh"
source "$SCRIPT_DIR/theme.d/editor_shell.sh"
source "$SCRIPT_DIR/theme.d/system.sh"
source "$SCRIPT_DIR/theme.d/nvim.sh"

case "${1:-}" in
  "") pick_theme ;;
  update) update_catppuccin ;;
  list) list_themes ;;
  current)
    if [[ -f "$CURRENT_FILE" ]]; then cat "$CURRENT_FILE"; else echo "No current theme set"; exit 1; fi
    ;;
  apply)
    if [[ "${2:-}" == "" ]]; then usage; exit 1; fi
    if [[ "$2" == "current" ]]; then
      if [[ ! -f "$CURRENT_FILE" ]]; then echo "No current theme set" >&2; exit 1; fi
      apply_theme "$(cat "$CURRENT_FILE")"
    else
      apply_theme "$2"
    fi
    ;;
  *) usage; exit 1 ;;
esac
