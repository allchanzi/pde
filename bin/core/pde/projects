def list_picker_lines(projects: list[Project]) -> list[str]:
    """Return picker display lines."""

    return [f"{project.slug}\t{project.name}\t{project.path}" for project in projects]


def pick_one_from_list(prompt: str, lines: list[str]) -> str:
    """Pick one value using fzf or numbered fallback."""

    if not lines:
        fail("No projects to choose from.")
    if command_exists("fzf"):
        completed = subprocess.run(
            [
                "fzf",
                "--prompt",
                f"  {prompt}: ",
                "--pointer",
                "▶",
                "--highlight-line",
                "--no-info",
                "--height",
                "~14",
                "--border",
                "rounded",
            ],
            input="\n".join(lines),
            text=True,
            capture_output=True,
            check=False,
        )
        if completed.returncode != 0 or not completed.stdout.strip():
            fail("Selection cancelled.")
        return completed.stdout.strip()
    for index, line in enumerate(lines, start=1):
        print(f"{index:>2}. {line}")
    choice = input(f"{prompt} [1-{len(lines)}]: ").strip()
    if not choice.isdigit():
        fail("Invalid selection.")
    selected = int(choice)
    if selected < 1 or selected > len(lines):
        fail("Invalid selection.")
    return lines[selected - 1]


def pick_many_from_list(prompt: str, lines: list[str], defaults: list[str]) -> list[str]:
    """Pick multiple values."""

    if command_exists("fzf"):
        completed = subprocess.run(
            [
                "fzf",
                "--multi",
                "--prompt",
                f"  {prompt}: ",
                "--pointer",
                "▶",
                "--marker",
                "✓",
                "--highlight-line",
                "--no-info",
                "--height",
                "~14",
                "--border",
                "rounded",
            ],
            input="\n".join(lines),
            text=True,
            capture_output=True,
            check=False,
        )
        if completed.returncode != 0 or not completed.stdout.strip():
            return defaults
        return [line.strip() for line in completed.stdout.splitlines() if line.strip()]
    print(f"{prompt}: {', '.join(lines)}")
    entered = input(
        f"Comma-separated values [{', '.join(defaults)}]: "
    ).strip()
    if not entered:
        return defaults
    selected = [item.strip() for item in entered.split(",") if item.strip()]
    invalid = [item for item in selected if item not in lines]
    if invalid:
        fail(f"Unknown capabilities: {', '.join(invalid)}")
    return selected


def prompt_text(prompt: str, default: str | None = None, *, allow_empty: bool = False) -> str:
    """Prompt user for text."""

    suffix = f" [{default}]" if default else ""
    while True:
        value = input(f"{prompt}{suffix}: ").strip()
        if value:
            return value
        if default is not None:
            return default
        if allow_empty:
            return ""
        print("Value is required.")


def prompt_yes_no(prompt: str, default: bool = True) -> bool:
    """Prompt user for yes/no."""

    suffix = " [Y/n]" if default else " [y/N]"
    answer = input(f"{prompt}{suffix}: ").strip().lower()
    if not answer:
        return default
    return answer in {"y", "yes"}



def create_launcher_wrapper(
    project: Project,
    launcher_name: str,
    script_path: Path,
    *,
    interactive: bool,
) -> Path:
    """Create per-project wrapper launcher."""

    launcher_path = Path.home() / "bin" / launcher_name
    launcher_path.parent.mkdir(parents=True, exist_ok=True)
    if launcher_path.exists():
        if not interactive:
            fail(f"Launcher already exists: {launcher_path}")
        if not prompt_yes_no(
            f"Launcher {launcher_path} exists. Overwrite?",
            default=False,
        ):
            fail("Launcher creation cancelled.")
    launcher_path.write_text(
        "\n".join(
            (
                "#!/usr/bin/env bash",
                "set -euo pipefail",
                f'exec {shlex.quote(str(script_path))} open {shlex.quote(project.slug)} "$@"',
                "",
            )
        ),
        encoding="utf-8",
    )
    launcher_path.chmod(0o755)
    return launcher_path


def parsed_command_pairs(values: list[str]) -> dict[str, str]:
    """Parse repeated capability=command values."""

    commands: dict[str, str] = {}
    for value in values:
        if "=" not in value:
            fail(f"Expected capability=command, got: {value}")
        capability, command = value.split("=", 1)
        capability = capability.strip()
        command = command.strip()
        if not capability or not command:
            fail(f"Expected capability=command, got: {value}")
        commands[capability] = command
    return commands


def delete_wrapper_launcher(project: Project) -> bool:
    """Delete generated wrapper launcher when present."""

    if project.launcher_type != "wrapper" or not project.launcher:
        return False
    launcher_path = Path(project.launcher).expanduser()
    if not launcher_path.exists():
        return False
    launcher_path.unlink()
    return True


def extra_project_worktrees(project: Project) -> list[str]:
    """Return non-primary worktree branches for project."""

    if not project.path_obj.exists() or not is_git_repo(project.path_obj):
        return []
    return sorted(
        current_branch.removeprefix("refs/heads/")
        for current_path, current_branch in git_worktree_pairs(project.path_obj)
        if current_branch.startswith("refs/heads/")
        and Path(current_path).resolve() != project.path_obj.resolve()
    )


def delete_project(
    project: Project,
    arguments: argparse.Namespace,
    projects: list[Project],
) -> None:
    """Delete project from registry."""

    active_sessions = project_active_session_labels(
        project,
        active_tmux_sessions(),
        active_zellij_sessions(),
    )
    worktrees = extra_project_worktrees(project)
    launcher_text = (
        f" and remove launcher {project.launcher}"
        if project.launcher_type == "wrapper" and project.launcher and not arguments.keep_launcher
        else ""
    )
    prompt = (
        f"Delete project '{project.name}' from registry{launcher_text}? "
        f"Project files at {project.path} will stay on disk."
    )
    if not arguments.yes:
        if not sys.stdin.isatty():
            fail("Project deletion requires --yes in non-interactive mode.")
        if not prompt_yes_no(prompt, default=False):
            fail("Project deletion cancelled.")

    save_registry([item for item in projects if item.slug != project.slug])
    launcher_deleted = not arguments.keep_launcher and delete_wrapper_launcher(project)

    print(f"Deleted project '{project.name}'")
    print(f"  registry → {PROJECTS_FILE}")
    print(f"  path     → kept on disk: {project.path}")
    if project.launcher:
        match launcher_deleted:
            case True:
                print(f"  launcher → removed: {project.launcher}")
            case False if arguments.keep_launcher:
                print(f"  launcher → kept: {project.launcher}")
            case _:
                print(f"  launcher → unchanged: {project.launcher}")
    if active_sessions:
        print(f"  sessions → still running: {', '.join(active_sessions)}")
    if worktrees:
        print(f"  worktree → kept: {', '.join(worktrees)}")


def register_project(arguments: argparse.Namespace, script_path: Path) -> None:
    """Register a new project."""

    projects = load_registry()
    interactive = sys.stdin.isatty()
    if arguments.name is None and not interactive:
        fail("Project name is required in non-interactive mode.")
    if arguments.path is None and not interactive:
        fail("Project path is required in non-interactive mode.")

    name = arguments.name or prompt_text("Project name")
    if any(project.name.lower() == name.lower() for project in projects):
        fail(f"Project '{name}' already exists.")

    project_path = resolve_path(arguments.path or prompt_text("Project path"))
    if not project_path.exists() and (
        not interactive
        or prompt_yes_no(
            f"Create project directory {project_path}?",
            default=True,
        )
    ):
        project_path.mkdir(parents=True, exist_ok=True)

    slug = next_unique_slug(projects, arguments.slug or name)
    capabilities = list(arguments.capability or [])
    if arguments.rtui:
        capabilities.append("rtui")
    if arguments.pantsui:
        capabilities.append("pantsui")
    if interactive and not capabilities:
        capabilities = pick_many_from_list(
            "Capabilities",
            list(KNOWN_CAPABILITIES),
            [],
        )
    capabilities = list(dict.fromkeys(capabilities))
    commands = parsed_command_pairs(arguments.command_pairs)
    layout_variant = arguments.layout_variant
    base_branch = arguments.base_branch

    repo_base_branch = detected_base_branch(project_path) if is_git_repo(project_path) else ""
    if base_branch is None:
        if interactive:
            base_branch = prompt_text(
                "Default base branch",
                repo_base_branch or "main",
                allow_empty=True,
            )
        else:
            base_branch = repo_base_branch or "main"
    if repo_base_branch and not resolve_base_start_point(project_path, base_branch):
        fail(
            (
                f"Base branch '{base_branch}' was not found for repository {project_path}. "
                f"Detected default branch: '{repo_base_branch}'."
            )
        )
    if layout_variant is None:
        if interactive:
            layout_variant = pick_one_from_list("Layout", ["minimal", "full", "custom"]).strip()
        else:
            layout_variant = "minimal"

    project = Project(
        slug=slug,
        name=name,
        path=str(project_path),
        base_branch=base_branch or None,
        layout_variant=layout_variant or None,
        capabilities=capabilities,
        commands=commands,
    )

    create_launcher = arguments.create_launcher
    if not arguments.create_launcher and not arguments.no_launcher and interactive:
        create_launcher = prompt_yes_no("Create launcher alias in ~/bin?", default=False)
    if create_launcher:
        launcher_name = arguments.launcher_name or (
            prompt_text("Launcher name", project.slug) if interactive else project.slug
        )
        launcher_path = create_launcher_wrapper(
            project,
            launcher_name,
            script_path,
            interactive=interactive,
        )
        project.launcher = str(launcher_path)
        project.launcher_type = "wrapper"

    projects.append(project)
    save_registry(projects)
    print(f"Registered project '{project.name}'")
    print(f"  slug   → {project.slug}")
    print(f"  path   → {project.path}")
    print(f"  file   → {PROJECTS_FILE}")
    if project.launcher:
        print(f"  alias  → {project.launcher}")


def open_docs(project: Project) -> None:
    """Open docs for project."""

    ensure_project_path(project)
    raise SystemExit(shell_exec(default_docs_command(project), cwd=project.path_obj))


def run_capability(project: Project, capability: str) -> None:
    """Run named project capability."""

    ensure_project_path(project)
    command = project.commands.get(capability)
    if command is None:
        match capability:
            case "docs":
                command = default_docs_command(project)
            case "files":
                command = default_files_command(project)
            case "requests" | "rtui":
                command = default_rtui_command(project)
            case "pantsui":
                command = default_pantsui_command(project)
            case _:
                available = ", ".join(sorted(project.commands)) or "none"
                fail(
                    f"Project '{project.name}' has no command for capability '{capability}'. "
                    f"Available commands: {available}"
                )
    raise SystemExit(shell_exec(command, cwd=project.path_obj))


def tool_shell(project: Project) -> None:
    """Print project tool summary."""

    ensure_project_path(project)
    print(f"Project: {project.name}")
    print(f"Path:    {project.path}")
    if project.capabilities:
        print(f"Capabilities: {', '.join(project.capabilities)}")
    else:
        print("Capabilities: none configured")
    print("")
    if project.commands:
        print("Available commands:")
        for capability, command in project.commands.items():
            print(f"  {capability:<12} projects run {project.slug} {capability}")
            print(f"  {'':12} {command}")
    else:
        print("No custom commands configured.")
    print("")
    print("Tip:")
    print(f"  projects info {project.slug}")


def picker_open(script_path: Path) -> None:
    """Pick and open a project."""

    projects = load_registry()
    selected = pick_one_from_list("Projects", list_picker_lines(projects))
    slug = selected.split("\t", 1)[0]
    open_project(
        find_project(projects, slug),
        parse_prefs(),
        script_path,
        branch=None,
        from_branch=None,
        force=False,
    )


def open_project(
    project: Project,
    runtime: RuntimePrefs,
    script_path: Path,
    *,
    branch: str | None,
    from_branch: str | None,
    force: bool,
) -> None:
    """Open project in configured multiplexer."""

    project_dir, session_name = project_dir_for_code_open(project, branch, from_branch, force)

    tabs = project_tabs(project, runtime, script_path)
    if runtime.multiplexer == "zellij":
        layout_path = custom_zellij_layout(project)
        if layout_path is None:
            layout_path = write_zellij_layout(tabs, session_name)
        open_in_zellij(session_name, project_dir, layout_path)
    open_in_tmux(project, session_name, project_dir, tabs)


def build_parser() -> argparse.ArgumentParser:
    """Build CLI parser."""

    parser = argparse.ArgumentParser(
        prog="projects",
        add_help=False,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description="Registry-driven PDE project manager.",
        epilog=PROJECTS_HELP,
    )
    parser.add_argument("-h", "--help", action="store_true")
    subparsers = parser.add_subparsers(dest="command")

    open_parser = subparsers.add_parser("open", add_help=False)
    open_parser.add_argument("project", nargs="?")
    open_parser.add_argument("-b", "--branch")
    open_parser.add_argument("--from", dest="from_branch")
    open_parser.add_argument("-f", "--force", action="store_true")
    open_parser.add_argument("--list-worktrees", action="store_true")
    open_parser.add_argument("--delete-worktree", action="store_true")
    open_parser.add_argument("--worktree-origin", action="store_true")
    open_parser.add_argument("-h", "--help", action="store_true")

    list_parser = subparsers.add_parser("list", add_help=False)
    list_parser.add_argument("-h", "--help", action="store_true")

    info_parser = subparsers.add_parser("info", add_help=False)
    info_parser.add_argument("project")
    info_parser.add_argument("-h", "--help", action="store_true")

    run_parser = subparsers.add_parser("run", add_help=False)
    run_parser.add_argument("project")
    run_parser.add_argument("capability")
    run_parser.add_argument("-h", "--help", action="store_true")

    register_parser = subparsers.add_parser("register", add_help=False, aliases=["add"])
    register_parser.add_argument("name", nargs="?")
    register_parser.add_argument("path", nargs="?")
    register_parser.add_argument("--slug")
    register_parser.add_argument("--base-branch")
    register_parser.add_argument("--layout-variant", choices=("minimal", "full", "custom"))
    register_parser.add_argument("--capability", action="append", default=[])
    register_parser.add_argument("--rtui", action="store_true")
    register_parser.add_argument("--pantsui", action="store_true")
    register_parser.add_argument("--command", dest="command_pairs", action="append", default=[])
    register_parser.add_argument("--create-launcher", action="store_true")
    register_parser.add_argument("--launcher-name")
    register_parser.add_argument("--no-launcher", action="store_true")
    register_parser.add_argument("-h", "--help", action="store_true")

    delete_parser = subparsers.add_parser(
        "delete",
        add_help=False,
        aliases=["remove", "rm", "unregister"],
    )
    delete_parser.add_argument("project")
    delete_parser.add_argument("--yes", action="store_true")
    delete_parser.add_argument("--keep-launcher", action="store_true")
    delete_parser.add_argument("-h", "--help", action="store_true")

    open_docs_parser = subparsers.add_parser("open-docs", add_help=argparse.SUPPRESS)
    open_docs_parser.add_argument("project")

    tool_shell_parser = subparsers.add_parser("tool-shell", add_help=argparse.SUPPRESS)
    tool_shell_parser.add_argument("project")

    inspect_parser = subparsers.add_parser("inspect", add_help=argparse.SUPPRESS)
    inspect_parser.add_argument("project")

    return parser


def command_or_default(arguments: list[str]) -> list[str]:
    """Insert default command when omitted."""

    if not arguments:
        return ["open"]
    if arguments[0] in {
        "open",
        "list",
        "info",
        "run",
        "register",
        "add",
        "delete",
        "remove",
        "rm",
        "unregister",
        "open-docs",
        "tool-shell",
        "inspect",
    }:
        return arguments
    if arguments[0] in {"-h", "--help"}:
        return arguments
    return ["open", *arguments]


def main(argv: list[str] | None = None) -> None:
    """CLI entrypoint."""

    script_path = Path(sys.argv[0]).resolve()
    public_wrapper = script_path.parent.parent.parent / "projects"
    if (
        script_path.parent.name == "pde"
        and script_path.parent.parent.name == "core"
        and public_wrapper.exists()
    ):
        script_path = public_wrapper.resolve()
    parser = build_parser()
    normalized_arguments = command_or_default(list(sys.argv[1:] if argv is None else argv))
    namespace = parser.parse_args(normalized_arguments)

    if namespace.help:
        print_usage()
        return

    projects = load_registry()
    runtime = parse_prefs()

    match namespace.command:
        case "list":
            list_projects(projects)
        case "info":
            print_project_info(find_project(projects, namespace.project))
        case "run":
            run_capability(find_project(projects, namespace.project), namespace.capability)
        case "register" | "add":
            register_project(namespace, script_path)
        case "delete" | "remove" | "rm" | "unregister":
            delete_project(
                find_project(projects, namespace.project),
                namespace,
                projects,
            )
        case "open-docs":
            open_docs(find_project(projects, namespace.project))
        case "tool-shell":
            tool_shell(find_project(projects, namespace.project))
        case "inspect":
            print_project_inspect_json(find_project(projects, namespace.project))
        case "open":
            if namespace.project is None:
                picker_open(script_path)
                return
            project = find_project(projects, namespace.project)
            if namespace.list_worktrees or namespace.delete_worktree or namespace.worktree_origin:
                ensure_project_path(project)
                if not is_git_repo(project.path_obj):
                    fail(f"Project '{project.name}' is not a git repository.")
                maybe_delegate_to_external_launcher(
                    project,
                    branch=namespace.branch,
                    from_branch=namespace.from_branch,
                    force=namespace.force,
                    list_worktrees=namespace.list_worktrees,
                    delete_worktree_flag=namespace.delete_worktree,
                    worktree_origin_flag=namespace.worktree_origin,
                )
                if namespace.list_worktrees:
                    print(capture_command(["git", "worktree", "list"], cwd=project.path_obj))
                    return
                if namespace.delete_worktree:
                    if not namespace.branch:
                        fail("--delete-worktree requires -b <branch>")
                    delete_worktree(project.path_obj, namespace.branch)
                    return
                if namespace.worktree_origin:
                    if not namespace.branch:
                        fail("--worktree-origin requires -b <branch>")
                    show_worktree_origin(project.path_obj, namespace.branch)
                    return
            maybe_delegate_to_external_launcher(
                project,
                branch=namespace.branch,
                from_branch=namespace.from_branch,
                force=namespace.force,
                list_worktrees=False,
                delete_worktree_flag=False,
                worktree_origin_flag=False,
            )
            open_project(
                project,
                runtime,
                script_path,
                branch=namespace.branch,
                from_branch=namespace.from_branch,
                force=namespace.force,
            )
        case _:
            print_usage()
            raise SystemExit(1)


if __name__ == "__main__":
    main()
