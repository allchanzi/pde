    print(f"{'NAME':<{name_width}}  {'SLUG':<{slug_width}}  {'SESSIONS':<{sessions_width}}  PATH")
    for project in projects:
        print(f"{project.name:<{name_width}}  {project.slug:<{slug_width}}  {sessions_by_slug[project.slug]:<{sessions_width}}  {project.path}")


