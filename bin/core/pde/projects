    """Print project details as JSON for TUI helpers."""

    tmux_sessions = active_tmux_sessions()
    zellij_sessions = active_zellij_sessions()
    base_session = project_session_name(project)
    rows: list[dict[str, Any]] = [
        {
            "kind": "main",
            "label": "main workspace",
            "branch": None,
            "path": str(project.path_obj),
            "session_name": base_session,
            "tmux_active": base_session in tmux_sessions,
