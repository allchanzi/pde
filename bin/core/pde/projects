import os
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

PREFS_DEFAULT = Path(
    os.environ.get("PDE_PREFS_FILE_DEFAULT", "~/.config/pde/prefs")
).expanduser()
PREFS_LEGACY = Path(
    os.environ.get("PDE_PREFS_FILE_LEGACY", "~/.config/config/prefs")
).expanduser()
PREFS_LEGACY_SHELL = Path(
    os.environ.get("PDE_PREFS_FILE_LEGACY_SHELL", "~/.config/shell/prefs")
).expanduser()
PROJECTS_FILE = Path(
    os.environ.get("PDE_PROJECTS_FILE", "~/.config/pde/projects.json")
).expanduser()
LAYOUT_DIR = Path.home() / ".config" / "pde" / "layouts" / "projects"
ZELLIJ_LAYOUT_DIR = Path.home() / ".config" / "zellij" / "layouts"
TMUX_LAYOUT_DIR = Path.home() / ".config" / "tmux"
PROJECTS_HELP = """Usage:
  projects
  projects open <project> [-b <branch>] [--from <base-branch>] [-f]
  projects list
  projects register [name] [path]
  projects delete <project> [--yes] [--keep-launcher]
  projects info <project>
  projects run <project> <capability>

Examples:
  projects
  projects open my-project -b feature/login
  projects register my-project ~/projects/my-project
  projects register my-project ~/projects/my-project --rtui --pantsui
"""

KNOWN_CAPABILITIES = ("rtui", "pantsui", "requests")


@dataclass(slots=True)
class RuntimePrefs:
    """Runtime PDE preferences."""

    multiplexer: str = "tmux"
    ai_profile: str = "codex+claude"
    ai_command_1: str = "codex"
    ai_command_2: str = "claude"


@dataclass(slots=True)
class Project:
    """Project registry entry."""

    slug: str
    name: str
    path: str
    launcher: str | None = None
    launcher_type: str | None = None
    base_branch: str | None = None
    layout_variant: str | None = None
    tags: list[str] = field(default_factory=list)
    capabilities: list[str] = field(default_factory=list)
    commands: dict[str, str] = field(default_factory=dict)

    @property
    def path_obj(self) -> Path:
        """Return project path as Path."""

        return Path(self.path).expanduser()

    def to_dict(self) -> dict[str, Any]:
        """Serialize project to JSON-compatible dict."""

        data = {
            "slug": self.slug,
            "name": self.name,
            "path": self.path,
            "tags": self.tags,
            "capabilities": self.capabilities,
            "commands": self.commands,
        }
        if self.launcher:
            data["launcher"] = self.launcher
        if self.launcher_type:
            data["launcher_type"] = self.launcher_type
        if self.base_branch:
            data["base_branch"] = self.base_branch
        if self.layout_variant:
            data["layout_variant"] = self.layout_variant
        return data

    @classmethod
    def from_dict(cls, data: dict[str, Any]) -> "Project":
        """Build validated project from raw dict."""

        commands = data.get("commands", {})
        if not isinstance(commands, dict):
            raise ValueError("Project commands must be a mapping.")

        capabilities = data.get("capabilities", [])
        if not isinstance(capabilities, list):
            raise ValueError("Project capabilities must be a list.")

        slug = str(data.get("slug", "")).strip()
        name = str(data.get("name", "")).strip()
        path = str(data.get("path", "")).strip()
        if not slug or not name or not path:
            raise ValueError("Projects require slug, name, and path.")

        normalized_commands = {
            str(key).strip(): str(value).strip()
            for key, value in commands.items()
            if str(key).strip() and str(value).strip()
        }
        normalized_capabilities = [
            str(item).strip() for item in capabilities if str(item).strip()
        ]
        return cls(
            slug=slug,
            name=name,
            path=path,
            launcher=str(data.get("launcher", "")).strip() or None,
            launcher_type=str(data.get("launcher_type", "")).strip() or None,
            base_branch=str(data.get("base_branch", "")).strip() or None,
            layout_variant=str(data.get("layout_variant", "")).strip() or None,
            tags=[
                str(item).strip()
                for item in data.get("tags", [])
                if str(item).strip()
            ],
            capabilities=normalized_capabilities,
            commands=normalized_commands,
        )


@dataclass(slots=True)
class TabSpec:
    """Multiplexer tab/window spec."""

    name: str
    command: str | None = None
    split_commands: list[str] = field(default_factory=list)
    focus: bool = False


def print_usage() -> None:
    """Print top-level usage."""

    print(PROJECTS_HELP.rstrip())


def fail(message: str) -> None:
    """Exit with error."""

    raise SystemExit(message)


def run_command(
    command: list[str],
    *,
    cwd: Path | None = None,
    capture_output: bool = False,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    """Run subprocess command."""

    return subprocess.run(
        command,
        cwd=str(cwd) if cwd else None,
        capture_output=capture_output,
        check=check,
        text=True,
    )


def capture_command(command: list[str], *, cwd: Path | None = None) -> str:
    """Run command and return stdout."""

    return run_command(command, cwd=cwd, capture_output=True).stdout.strip()


def resolve_path(value: str) -> Path:
    """Resolve user-provided path."""

    expanded = Path(value).expanduser()
    if expanded.exists():
        return expanded.resolve()
    return Path(os.path.abspath(str(expanded)))


def slugify(value: str) -> str:
    """Convert text to slug."""

    normalized = re.sub(r"[^a-zA-Z0-9]+", "-", value.strip().lower()).strip("-")
    return normalized or "project"


def registry_parent() -> Path:
    """Return registry parent directory."""

    return PROJECTS_FILE.parent


def ensure_registry_exists() -> None:
    """Create empty registry when missing."""

    if PROJECTS_FILE.exists():
        return
    registry_parent().mkdir(parents=True, exist_ok=True)
    PROJECTS_FILE.write_text(
        json.dumps({"version": 1, "projects": []}, indent=2) + "\n",
        encoding="utf-8",
    )


def load_registry() -> list[Project]:
    """Load registry from disk."""

    ensure_registry_exists()
    raw = json.loads(PROJECTS_FILE.read_text(encoding="utf-8"))
    projects = raw.get("projects", [])
    if not isinstance(projects, list):
        fail(f"Invalid registry format in {PROJECTS_FILE}.")
    try:
        loaded = [Project.from_dict(project) for project in projects]
    except ValueError as error:
        fail(f"Invalid registry entry: {error}")
    return sorted(loaded, key=lambda project: project.name.lower())


def save_registry(projects: list[Project]) -> None:
    """Persist registry atomically."""

    registry_parent().mkdir(parents=True, exist_ok=True)
    data = {
        "version": 1,
        "projects": [project.to_dict() for project in sorted(projects, key=lambda item: item.name.lower())],
    }
    with tempfile.NamedTemporaryFile(
        "w",
        delete=False,
        dir=str(registry_parent()),
        encoding="utf-8",
    ) as file_handle:
        json.dump(data, file_handle, indent=2)
        file_handle.write("\n")
    Path(file_handle.name).replace(PROJECTS_FILE)


def find_project(projects: list[Project], query: str) -> Project:
    """Find project by slug or name."""

    normalized = query.strip().lower()
    matches = [
        project
        for project in projects
        if project.slug.lower() == normalized or project.name.lower() == normalized
    ]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        fail(f"Ambiguous project name: {query}")
    for project in projects:
        if normalized in {project.slug.lower(), project.name.lower()}:
            return project
    fail(f"Unknown project: {query}")


def find_project_or_none(projects: list[Project], query: str) -> Project | None:
    """Return project or None."""

    normalized = query.strip().lower()
    for project in projects:
        if project.slug.lower() == normalized or project.name.lower() == normalized:
            return project
    return None


def next_unique_slug(projects: list[Project], base: str) -> str:
    """Generate unique slug."""

    slug = slugify(base)
    existing = {project.slug for project in projects}
    if slug not in existing:
        return slug
    index = 2
    while f"{slug}-{index}" in existing:
        index += 1
    return f"{slug}-{index}"


def resolve_prefs_file() -> Path:
    """Resolve active prefs file."""

    if PREFS_DEFAULT.exists():
        return PREFS_DEFAULT
    if PREFS_LEGACY.exists():
        return PREFS_LEGACY
    if PREFS_LEGACY_SHELL.exists():
        return PREFS_LEGACY_SHELL
    return PREFS_DEFAULT


def parse_prefs() -> RuntimePrefs:
    """Load PDE prefs."""

    prefs = RuntimePrefs()
    prefs_file = resolve_prefs_file()
    if prefs_file.exists():
        for line in prefs_file.read_text(encoding="utf-8").splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith("#") or "=" not in stripped:
                continue
            try:
                token = shlex.split(stripped, comments=True, posix=True)[0]
            except ValueError:
                continue
            if "=" not in token:
                continue
            key, value = token.split("=", 1)
            match key:
                case "MULTIPLEXER":
                    prefs.multiplexer = value or prefs.multiplexer
                case "AI_PROFILE":
                    prefs.ai_profile = value or prefs.ai_profile
                case "AI_COMMAND_1":
                    prefs.ai_command_1 = value or prefs.ai_command_1
                case "AI_COMMAND_2":
                    prefs.ai_command_2 = value or prefs.ai_command_2

    prefs.multiplexer = os.environ.get("MULTIPLEXER", prefs.multiplexer)
    prefs.ai_profile = os.environ.get("AI_PROFILE", prefs.ai_profile)
    prefs.ai_command_1 = os.environ.get("AI_COMMAND_1", prefs.ai_command_1)
    prefs.ai_command_2 = os.environ.get("AI_COMMAND_2", prefs.ai_command_2)
    if prefs.ai_profile == "none":
        prefs.ai_command_1 = ""
        prefs.ai_command_2 = ""
    return prefs


def terminal_shell() -> str:
    """Return preferred shell."""

    return os.environ.get("SHELL", "/bin/zsh")


def shell_wrap(command: str) -> str:
    """Wrap command so zellij pane returns to shell."""

    return f'{command}; exec "$SHELL" -l'


def shell_exec(command: str, *, cwd: Path) -> int:
    """Execute shell command in cwd."""

    completed = subprocess.run(
        command,
        cwd=str(cwd),
        shell=True,
        executable=terminal_shell(),
        check=False,
    )
    return completed.returncode


def command_exists(command: str) -> bool:
    """Check whether command exists."""

    return shutil.which(command) is not None


def default_files_command(project: Project) -> str:
    """Return files command for project."""

    if project.commands.get("files"):
        return project.commands["files"]
    for binary, command in (
        ("yazi", "yazi ."),
        ("lf", "lf"),
        ("nnn", "nnn ."),
        ("ranger", "ranger"),
    ):
        if command_exists(binary):
            return command
    return "nvim ."


def default_docs_command(project: Project) -> str:
    """Return docs command for project."""

    if project.commands.get("docs"):
        return project.commands["docs"]
    for candidate in (
        project.path_obj / "README.md",
        project.path_obj / "docs" / "README.md",
        project.path_obj / "docs" / "index.md",
    ):
        if candidate.exists():
            return f"nvim {shlex.quote(str(candidate.relative_to(project.path_obj)))}"
    if project.commands.get("mindmap"):
        return project.commands["mindmap"]
    return "nvim ."


def default_rtui_command(project: Project) -> str:
    """Return rtui command for project."""

    if project.commands.get("rtui"):
        return project.commands["rtui"]
    if project.commands.get("requests"):
        return project.commands["requests"]
    return "rtui ."


def default_pantsui_command(project: Project) -> str:
    """Return pantsui command for project."""

    if project.commands.get("pantsui"):
        return project.commands["pantsui"]
    return "pantsui"


def default_git_command() -> str:
    """Return git window command."""

    if command_exists("lazygit"):
        return "lazygit"
    return 'git status; printf "\\n"'


def default_monitor_tabs() -> list[TabSpec]:
    """Return extra full-layout tabs."""

    monitor_left = (
        "if command -v network-ports >/dev/null 2>&1; then "
        "network-ports; "
        "else bash -lc 'while true; do clear; lsof -nP -iTCP; sleep 2; done'; "
        "fi"
    )
    return [
        TabSpec(name="docker", command="lazydocker"),
        TabSpec(name="k9s", command="k9s"),
        TabSpec(
            name="monitor",
            split_commands=[monitor_left, "btop -p 1"],
        ),
    ]


def ai_tab(runtime: RuntimePrefs) -> TabSpec | None:
    """Build AI tab when enabled."""

    if runtime.ai_profile == "none" or not runtime.ai_command_1:
        return None
    if runtime.ai_command_2:
        return TabSpec(
            name="ai",
            split_commands=[runtime.ai_command_1, runtime.ai_command_2],
        )
    return TabSpec(name="ai", command=runtime.ai_command_1)


def project_session_name(project: Project) -> str:
    """Return base session name."""

    return project.slug


def project_tabs(project: Project, runtime: RuntimePrefs, script_path: Path) -> list[TabSpec]:
    """Build session tabs for project."""

    tabs = [
        TabSpec(name="terminal", focus=True),
        TabSpec(name="editor", command="nvim ."),
    ]
    match ai_tab(runtime):
        case TabSpec() as tab:
            tabs.append(tab)
        case _:
            pass
    tabs.extend(
        [
            TabSpec(name="git", command=default_git_command()),
            TabSpec(name="term2"),
        ]
    )
    if "requests" in project.capabilities or "rtui" in project.capabilities:
        tabs.append(TabSpec(name="rtui", command=default_rtui_command(project)))
    if "pantsui" in project.capabilities:
        tabs.append(TabSpec(name="pantsui", command=default_pantsui_command(project)))
    if project.layout_variant == "full":
        tabs.extend(default_monitor_tabs())
    return tabs


def custom_zellij_layout(project: Project) -> Path | None:
    """Return custom zellij layout when present."""

    for candidate in (
        ZELLIJ_LAYOUT_DIR / f"{project.slug}.local.kdl",
        ZELLIJ_LAYOUT_DIR / f"{project.slug}.kdl",
    ):
        if candidate.exists():
            return candidate
    return None


def custom_tmux_layout(project: Project) -> Path | None:
    """Return custom tmux layout when present."""

    for candidate in (
        TMUX_LAYOUT_DIR / f"{project.slug}.local.sh",
        TMUX_LAYOUT_DIR / f"{project.slug}.sh",
    ):
        if candidate.exists():
            return candidate
    return None


def zellij_escape(value: str) -> str:
    """Escape KDL string."""

    return value.replace("\\", "\\\\").replace('"', '\\"')


def write_zellij_layout(tabs: list[TabSpec], session_name: str) -> Path:
    """Write zellij layout for project session."""

    LAYOUT_DIR.mkdir(parents=True, exist_ok=True)
    layout_path = LAYOUT_DIR / f"{session_name}.kdl"
    lines = [
        "layout {",
        "    default_tab_template {",
        '        pane size=1 borderless=true {',
        '            plugin location="tab-bar"',
        "        }",
        "        children",
        '        pane size=2 borderless=true {',
        '            plugin location="status-bar"',
        "        }",
        "    }",
        "",
    ]
    for tab in tabs:
        focus_suffix = " focus=true" if tab.focus else ""
        lines.append(f'    tab name="{tab.name}"{focus_suffix} {{')
        if tab.split_commands:
            lines.append('        pane split_direction="vertical" {')
            for command in tab.split_commands:
                wrapped = zellij_escape(shell_wrap(command))
                lines.extend(
                    [
                        '            pane command="zsh" {',
                        f'                args "-lc" "{wrapped}"',
                        "            }",
                    ]
                )
            lines.append("        }")
        elif tab.command:
            wrapped = zellij_escape(shell_wrap(tab.command))
            lines.extend(
                [
                    '        pane command="zsh" {',
                    f'            args "-lc" "{wrapped}"',
                    "        }",
                ]
            )
        else:
            lines.append("        pane")
        lines.append("    }")
    lines.append("}")
    layout_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return layout_path


def zellij_session_exists(session_name: str) -> bool:
    """Check zellij session presence."""

    completed = run_command(
        ["zellij", "list-sessions", "--short", "--no-formatting"],
        capture_output=True,
        check=False,
    )
    return session_name in completed.stdout.splitlines()


def shorten_zellij_session_name(value: str) -> str:
    """Shorten zellij session name."""

    max_length = 24
    if len(value) <= max_length:
        return value
    import hashlib

    hash_suffix = hashlib.sha1(value.encode("utf-8")).hexdigest()[:8]
    prefix_length = max_length - len(hash_suffix) - 1
    return f"{value[:prefix_length]}-{hash_suffix}"


def tmux_has_session(session_name: str) -> bool:
    """Check tmux session presence."""

    completed = run_command(
        ["tmux", "has-session", "-t", session_name],
        check=False,
    )
    return completed.returncode == 0


def active_tmux_sessions() -> list[str]:
    """Return active tmux session names."""

    completed = run_command(
        ["tmux", "list-sessions", "-F", "#S"],
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        return []
    return sorted({line.strip() for line in completed.stdout.splitlines() if line.strip()})


def active_zellij_sessions() -> list[str]:
    """Return active zellij session names."""

    completed = run_command(
        ["zellij", "list-sessions", "--short", "--no-formatting"],
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        return []
    return sorted({line.strip() for line in completed.stdout.splitlines() if line.strip()})


def configure_tmux_window(
    session_name: str,
    index: int,
    tab: TabSpec,
    project_dir: Path,
) -> None:
    """Configure tmux window contents."""

    target = f"{session_name}:{index}"
    if tab.split_commands:
        run_command(["tmux", "split-window", "-h", "-t", target, "-c", str(project_dir)])
        run_command(["tmux", "send-keys", "-t", f"{target}.1", tab.split_commands[0], "C-m"])
        run_command(["tmux", "send-keys", "-t", f"{target}.2", tab.split_commands[1], "C-m"])
        return
    if tab.command:
        run_command(["tmux", "send-keys", "-t", target, tab.command, "C-m"])


def run_custom_tmux_layout(project: Project, session_name: str, project_dir: Path) -> bool:
    """Run custom tmux layout when configured."""

    match custom_tmux_layout(project):
        case Path() as layout_path:
            command = " && ".join(
                (
                    f"source {shlex.quote(str(layout_path))}",
                    "declare -F setup_tmux_layout >/dev/null 2>&1",
                    f"setup_tmux_layout {shlex.quote(session_name)} {shlex.quote(str(project_dir))}",
                )
            )
            completed = subprocess.run(
                command,
                shell=True,
                executable="/bin/bash",
                check=False,
            )
            return completed.returncode == 0
        case _:
            return False


def open_in_tmux(
    project: Project,
    session_name: str,
    project_dir: Path,
    tabs: list[TabSpec],
) -> None:
    """Open project in tmux."""

    attach_command = (
        ["tmux", "switch-client", "-t", session_name]
        if os.environ.get("TMUX")
        else ["tmux", "attach-session", "-t", session_name]
    )
    if tmux_has_session(session_name):
        os.execvp("tmux", attach_command)
    if run_custom_tmux_layout(project, session_name, project_dir):
        os.execvp("tmux", attach_command)
    first_tab, *other_tabs = tabs
    run_command(
        [
            "tmux",
            "new-session",
            "-d",
            "-s",
            session_name,
            "-n",
            first_tab.name,
            "-c",
            str(project_dir),
        ]
    )
    configure_tmux_window(session_name, 1, first_tab, project_dir)
    for index, tab in enumerate(other_tabs, start=2):
        run_command(
            [
                "tmux",
                "new-window",
                "-t",
                f"{session_name}:{index}",
                "-n",
                tab.name,
                "-c",
                str(project_dir),
            ]
        )
        configure_tmux_window(session_name, index, tab, project_dir)
    run_command(["tmux", "select-window", "-t", f"{session_name}:1"])
    os.execvp("tmux", attach_command)


def open_in_zellij(session_name: str, project_dir: Path, layout_path: Path) -> None:
    """Open project in zellij."""

    short_session = shorten_zellij_session_name(session_name)
    if os.environ.get("ZELLIJ"):
        os.execvp(
            "zellij",
            [
                "zellij",
                "action",
                "switch-session",
                short_session,
                "-c",
                str(project_dir),
                "-l",
                str(layout_path),
            ],
        )
    if zellij_session_exists(short_session):
        os.execvp("zellij", ["zellij", "attach", short_session])
    os.chdir(project_dir)
    os.execvp("zellij", ["zellij", "-s", short_session, "-n", str(layout_path)])


def ensure_project_path(project: Project) -> None:
    """Ensure project path exists."""

    if project.path_obj.exists():
        return
    fail(f"Project path does not exist: {project.path_obj}")


def is_git_repo(path: Path) -> bool:
    """Check git repository presence."""

    completed = run_command(
        ["git", "rev-parse", "--is-inside-work-tree"],
        cwd=path,
        check=False,
        capture_output=True,
    )
    return completed.returncode == 0 and completed.stdout.strip() == "true"


def git_worktree_pairs(path: Path) -> list[tuple[str, str]]:
    """Return worktree path/branch pairs."""

    output = capture_command(["git", "worktree", "list", "--porcelain"], cwd=path)
    current_path = ""
    pairs: list[tuple[str, str]] = []
    for line in output.splitlines():
        if line.startswith("worktree "):
            current_path = line.removeprefix("worktree ").strip()
            continue
        if line.startswith("branch "):
            pairs.append((current_path, line.removeprefix("branch ").strip()))
    return pairs


def worktree_path_for_branch(path: Path, branch: str) -> Path | None:
    """Return existing worktree path for branch."""

    target_branch = f"refs/heads/{branch}"
    for current_path, current_branch in git_worktree_pairs(path):
        if current_branch == target_branch:
            return Path(current_path)
    return None


def worktree_default_path(path: Path, branch: str) -> Path:
    """Return default worktree path."""

    safe_branch = branch.replace("/", "-")
    return path.parent / f"{path.name}-{safe_branch}"


def worktree_session_name(project: Project, branch: str) -> str:
    """Return session name for worktree."""

    safe_branch = branch.replace("/", "-")
    return f"{project_session_name(project)}-{safe_branch}"


def project_session_names(project: Project) -> list[str]:
    """Return possible session names for project."""

    sessions = {project_session_name(project)}
    if not project.path_obj.exists() or not is_git_repo(project.path_obj):
        return sorted(sessions)
    for _, current_branch in git_worktree_pairs(project.path_obj):
        if not current_branch.startswith("refs/heads/"):
            continue
        sessions.add(worktree_session_name(project, current_branch.removeprefix("refs/heads/")))
    return sorted(sessions)


def project_active_session_labels(
    project: Project,
    tmux_sessions: list[str],
    zellij_sessions: list[str],
) -> list[str]:
    """Return formatted active session labels for project."""

    base_session = project_session_name(project)
    expected_tmux = set(project_session_names(project))
    expected_zellij = {shorten_zellij_session_name(session) for session in expected_tmux}

    matching_tmux = sorted(
        {
            session
            for session in tmux_sessions
            if session in expected_tmux or session == base_session or session.startswith(f"{base_session}-")
        }
    )
    matching_zellij = sorted(
        {
            session
            for session in zellij_sessions
            if session in expected_zellij
            or session == shorten_zellij_session_name(base_session)
            or session.startswith(f"{shorten_zellij_session_name(base_session)}-")
        }
    )

    labels: list[str] = []
    if matching_tmux:
        labels.append(f"tmux:{','.join(matching_tmux)}")
    if matching_zellij:
        labels.append(f"zellij:{','.join(matching_zellij)}")
    return labels


def resolve_base_start_point(path: Path, branch: str) -> str:
    """Resolve local or remote base branch."""

    run_command(["git", "fetch", "origin", branch, "--prune"], cwd=path, check=False)
    if run_command(
        ["git", "show-ref", "--verify", "--quiet", f"refs/remotes/origin/{branch}"],
        cwd=path,
        check=False,
    ).returncode == 0:
        return f"origin/{branch}"
    if run_command(
        ["git", "show-ref", "--verify", "--quiet", f"refs/heads/{branch}"],
        cwd=path,
        check=False,
    ).returncode == 0:
        return branch
    return ""


def detected_base_branch(path: Path) -> str:
    """Detect likely default branch for repository."""

    origin_head = run_command(
        ["git", "symbolic-ref", "--quiet", "--short", "refs/remotes/origin/HEAD"],
        cwd=path,
        capture_output=True,
        check=False,
    ).stdout.strip()
    if origin_head.startswith("origin/"):
        return origin_head.removeprefix("origin/")

    current_head = run_command(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        cwd=path,
        capture_output=True,
        check=False,
    ).stdout.strip()
    if current_head and current_head != "HEAD":
        return current_head

    for candidate in ("main", "master", "develop"):
        if resolve_base_start_point(path, candidate):
            return candidate
    return ""


def resolved_project_base_start_point(path: Path, base_branch: str) -> str:
    """Resolve configured base branch or fall back to detected default."""

    if start_point := resolve_base_start_point(path, base_branch):
        return start_point

    if detected_branch := detected_base_branch(path):
        if detected_branch != base_branch:
            if start_point := resolve_base_start_point(path, detected_branch):
                print(
                    (
                        f"Warning: configured base branch '{base_branch}' was not found. "
                        f"Using detected branch '{detected_branch}' instead."
                    ),
                    file=sys.stderr,
                )
                return start_point

    fail(f"Base branch '{base_branch}' not found locally or on origin.")


def delete_local_branch_if_requested(path: Path, branch: str, force: bool) -> None:
    """Delete local branch when force-recreating worktree."""

    if run_command(
        ["git", "show-ref", "--verify", "--quiet", f"refs/heads/{branch}"],
        cwd=path,
        check=False,
    ).returncode != 0:
        return
    if not force:
        fail(
            f"Branch '{branch}' already exists locally. Use -f to recreate it from a different base."
        )
    run_command(["git", "branch", "-D", branch], cwd=path)


def local_branch_exists(path: Path, branch: str) -> bool:
    """Return whether local branch exists."""

    return (
        run_command(
            ["git", "show-ref", "--verify", "--quiet", f"refs/heads/{branch}"],
            cwd=path,
            check=False,
        ).returncode
        == 0
    )


def git_dir_for_path(path: Path) -> Path:
    """Resolve git dir path."""

    git_dir = capture_command(["git", "-C", str(path), "rev-parse", "--git-dir"])
    candidate = Path(git_dir)
    if candidate.is_absolute():
        return candidate
    return path / candidate


def write_worktree_metadata(
    worktree_path: Path,
    branch: str,
    origin_ref: str,
    origin_kind: str,
) -> None:
    """Persist worktree metadata."""

    metadata_path = git_dir_for_path(worktree_path) / "pde-worktree-meta"
    metadata_path.write_text(
        "\n".join(
            (
                f"branch={branch}",
                f"origin_ref={origin_ref}",
                f"origin_kind={origin_kind}",
                f"created_at={datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')}",
            )
        )
        + "\n",
        encoding="utf-8",
    )


def show_worktree_origin(path: Path, branch: str) -> None:
    """Print worktree origin details."""

    current_path = worktree_path_for_branch(path, branch)
    if current_path is None:
        fail(f"No worktree found for branch '{branch}'.")
    metadata_path = git_dir_for_path(current_path) / "pde-worktree-meta"
    print(f"worktree: {current_path}")
    print(f"branch:   {branch}")
    if metadata_path.exists():
        values: dict[str, str] = {}
        for line in metadata_path.read_text(encoding="utf-8").splitlines():
            if "=" not in line:
                continue
            key, value = line.split("=", 1)
            values[key] = value
        if values.get("origin_ref"):
            print(f"origin:   {values['origin_ref']}")
        if values.get("origin_kind"):
            print(f"kind:     {values['origin_kind']}")
        if values.get("created_at"):
            print(f"created:  {values['created_at']}")
        return
    upstream = run_command(
        [
            "git",
            "-C",
            str(current_path),
            "rev-parse",
            "--abbrev-ref",
            "--symbolic-full-name",
            "@{upstream}",
        ],
        capture_output=True,
        check=False,
    ).stdout.strip()
    if upstream:
        print(f"origin:   {upstream}")
        print("kind:     upstream")
        return
    print("origin:   unknown (worktree was created before metadata support)")


def delete_worktree(path: Path, branch: str) -> None:
    """Delete worktree for branch."""

    current_path = worktree_path_for_branch(path, branch)
    if current_path is None:
        current_path = worktree_default_path(path, branch)
    if not current_path.exists():
        fail(f"No worktree path found for branch '{branch}'.")
    run_command(["git", "worktree", "remove", "--force", str(current_path)], cwd=path, check=False)
    shutil.rmtree(current_path, ignore_errors=True)
    print(f"Removed worktree '{branch}' at {current_path}")


def project_dir_for_code_open(
    project: Project,
    branch: str | None,
    from_branch: str | None,
    force: bool,
) -> tuple[Path, str]:
    """Resolve code project directory and session."""

    ensure_project_path(project)
    if not is_git_repo(project.path_obj):
        if branch:
            fail(f"Project '{project.name}' is not a git repository.")
        return project.path_obj, project_session_name(project)
    if not branch:
        return project.path_obj, project_session_name(project)

    existing_path = worktree_path_for_branch(project.path_obj, branch)
    if existing_path and not force:
        return existing_path, worktree_session_name(project, branch)

    if existing_path and force:
        run_command(["git", "worktree", "remove", "--force", str(existing_path)], cwd=project.path_obj, check=False)
        shutil.rmtree(existing_path, ignore_errors=True)

    worktree_path = worktree_default_path(project.path_obj, branch)
    origin_ref = ""
    origin_kind = ""
    base_branch = from_branch or project.base_branch

    if base_branch:
        start_point = resolved_project_base_start_point(project.path_obj, base_branch)
        match local_branch_exists(project.path_obj, branch):
            case True if not force:
                origin_ref = branch
                origin_kind = "local-branch"
                run_command(
                    ["git", "worktree", "add", str(worktree_path), branch],
                    cwd=project.path_obj,
                )
            case _:
                delete_local_branch_if_requested(project.path_obj, branch, force)
                origin_ref = start_point
                origin_kind = (
                    "base-remote-branch"
                    if start_point.startswith("origin/")
                    else "base-local-branch"
                )
                run_command(
                    ["git", "worktree", "add", str(worktree_path), "-b", branch, start_point],
                    cwd=project.path_obj,
                )
    else:
        run_command(["git", "fetch", "origin", branch, "--prune"], cwd=project.path_obj, check=False)
        if local_branch_exists(project.path_obj, branch):
            origin_ref = branch
            origin_kind = "local-branch"
            run_command(["git", "worktree", "add", str(worktree_path), branch], cwd=project.path_obj)
        elif run_command(
            ["git", "show-ref", "--verify", "--quiet", f"refs/remotes/origin/{branch}"],
            cwd=project.path_obj,
            check=False,
        ).returncode == 0:
            origin_ref = f"origin/{branch}"
            origin_kind = "remote-branch"
            run_command(
                ["git", "worktree", "add", str(worktree_path), "-b", branch, f"origin/{branch}"],
                cwd=project.path_obj,
            )
            run_command(
                [
                    "git",
                    "-C",
                    str(worktree_path),
                    "branch",
                    "--set-upstream-to",
                    f"origin/{branch}",
                    branch,
                ],
                check=False,
            )
        else:
            origin_ref = capture_command(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=project.path_obj)
            origin_kind = "current-head"
            run_command(
                ["git", "worktree", "add", str(worktree_path), "-b", branch],
                cwd=project.path_obj,
            )

    write_worktree_metadata(worktree_path, branch, origin_ref, origin_kind)
    return worktree_path, worktree_session_name(project, branch)


def maybe_delegate_to_external_launcher(
    project: Project,
    *,
    branch: str | None,
    from_branch: str | None,
    force: bool,
    list_worktrees: bool,
    delete_worktree_flag: bool,
    worktree_origin_flag: bool,
) -> None:
    """Delegate open to external launcher when configured."""

    if project.launcher_type != "external" or not project.launcher:
        return
    launcher_command = project.launcher
    launcher_path = (
        str(Path(launcher_command).expanduser())
        if os.path.sep in launcher_command
        else launcher_command
    )
    executable = (
        launcher_path
        if os.path.sep in launcher_command
        else shutil.which(launcher_path)
    )
    if executable is None or (os.path.sep in launcher_command and not Path(executable).exists()):
        fail(f"Configured launcher not found: {launcher_command}")
    arguments = [launcher_path]
    if branch:
        arguments.extend(["-b", branch])
    if from_branch:
        arguments.extend(["--from", from_branch])
    if force:
        arguments.append("-f")
    if list_worktrees:
        arguments.append("--list-worktrees")
    if delete_worktree_flag:
        arguments.append("--delete-worktree")
    if worktree_origin_flag:
        arguments.append("--worktree-origin")
    os.execvp(launcher_path, arguments)


