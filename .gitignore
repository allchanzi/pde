# bin/ — only core scripts tracked; user-generated launchers are ignored
bin/*
!bin/pde
!bin/projects
!bin/pde-prefs
!bin/install-optionals
!bin/network-ports
!bin/run-and-return-to-shell
!bin/setup
!bin/theme
!bin/theme.d/
!bin/theme.d/*
!bin/ai-system-snapshot
!bin/process-analyze
!bin/pde-worktree
!bin/pde-shortcuts-help
!bin/pde-version
!bin/tmux-open-in-nvim
!bin/nvim-remote-open
!bin/core/
!bin/core/pde/
!bin/core/pde/pde
!bin/core/pde/projects
!bin/core/pde/pde-worktree

# zellij layouts — only pde.kdl is generic; project layouts are generated by PDE
presets/allc/dotfiles/zellij/layouts/*
!presets/allc/dotfiles/zellij/layouts/pde.kdl


# Lazygit runtime state (recent repos, last version check, etc.)
presets/allc/dotfiles/lazygit/state.yml

# Theme cache — downloaded at runtime by: theme update
.cache/
target/

# Local Docker development environment
/docker/*
!/docker/Dockerfile.complete
!/docker/Dockerfile.complete.dockerignore
!/docker/Dockerfile.flutter
!/docker/Dockerfile.flutter.dockerignore
!/docker/Dockerfile.pants-python
!/docker/Dockerfile.pants-python.dockerignore
!/docker/Dockerfile.python-pants-dev
!/docker/Dockerfile.python-pants-dev.dockerignore
!/docker/Dockerfile.remote
!/docker/Dockerfile.remote.dockerignore
!/docker/Dockerfile.rust
!/docker/Dockerfile.rust.dockerignore
!/docker/pde/
/docker/pde/*
!/docker/pde/entrypoint.sh
!/docker/pde/install-common-tools.sh
!/docker/pde/install.sh
!/docker/pde/zshrc

# Neovim runtime files
.nvimlog
.tmp-nvim-state/
nvim.log
presets/allc/dotfiles/nvim/.nvimlog
presets/allc/dotfiles/nvim/.tmp-nvim-state/

# k9s runtime state (logs and per-cluster config are machine-specific)
presets/allc/dotfiles/k9s/k9s.log
presets/allc/dotfiles/k9s/clusters/

# Machine-local shell overrides (work/company/machine-specific, not generic)
presets/allc/dotfiles/zsh/shell/local.zsh

# macOS
.DS_Store

.claude/settings.local.json

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
