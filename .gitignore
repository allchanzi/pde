# bin/ — only core scripts tracked; user-generated launchers (mkproj output) are ignored
bin/*
!bin/config
!bin/config-prefs
!bin/install-optionals
!bin/mkproj
!bin/network-ports
!bin/run-and-return-to-shell
!bin/setup
!bin/theme
!bin/ai-system-snapshot
!bin/tmux-open-in-nvim

# zellij layouts — only config.kdl is generic; project layouts are generated by mkproj
zellij/layouts/*
!zellij/layouts/config.kdl


# Lazygit runtime state (recent repos, last version check, etc.)
lazygit/state.yml

# Theme cache — downloaded at runtime by: theme update
.cache/

# Neovim runtime files
.nvimlog
.tmp-nvim-state/
nvim.log
nvim/.nvimlog
nvim/.tmp-nvim-state/

# macOS
.DS_Store
