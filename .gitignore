# bin/ — only core scripts tracked; user-generated launchers (pde-create output) are ignored
bin/*
!bin/pde
!bin/pde-prefs
!bin/install-optionals
!bin/pde-create
!bin/network-ports
!bin/run-and-return-to-shell
!bin/setup
!bin/theme
!bin/ai-system-snapshot
!bin/tmux-open-in-nvim

# zellij layouts — only pde.kdl is generic; project layouts are generated by pde-create
zellij/layouts/*
!zellij/layouts/pde.kdl


# Lazygit runtime state (recent repos, last version check, etc.)
lazygit/state.yml

# Theme cache — downloaded at runtime by: theme update
.cache/

# Neovim runtime files
.nvimlog
.tmp-nvim-state/
nvim.log
nvim/.nvimlog
nvim/.tmp-nvim-state/

# k9s runtime state (logs and per-cluster config are machine-specific)
k9s/k9s.log
k9s/clusters/

# macOS
.DS_Store
